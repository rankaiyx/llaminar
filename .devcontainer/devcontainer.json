{
    "name": "Llaminar CMake Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "INSTALL_CUDA": "true",
            "INSTALL_ROCM": "true"
        }
    },
    "workspaceFolder": "/workspaces/llaminar",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/llaminar,type=bind,consistency=cached",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/azure-cli:1": {},
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "moby": true,
            "installDockerBuildx": true,
            "dockerDashComposeVersion": "v2"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools-themes",
                "ms-python.python",
                "ms-python.pylint",
                "ms-python.debugpy",
                "openai.chatgpt",
                "GitHub.copilot-chat",
                "redhat.vscode-yaml",
                "ms-vscode.vscode-json",
                "bradlc.vscode-tailwindcss",
                "esbenp.prettier-vscode"
            ],
            "settings": {
                "cmake.configureOnOpen": true,
                "cmake.buildBeforeRun": true,
                "cmake.clearOutputBeforeBuild": true,
                "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
                "C_Cpp.default.cStandard": "c17",
                "C_Cpp.default.cppStandard": "c++20",
                "C_Cpp.default.compilerPath": "/usr/bin/gcc",
                "files.associations": {
                    "*.h": "c",
                    "*.hpp": "cpp",
                    "*.cpp": "cpp",
                    "*.cc": "cpp",
                    "*.cxx": "cpp",
                    "CMakeLists.txt": "cmake",
                    "*.cmake": "cmake"
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/workspaces/llaminar/.venv/bin/python",
                "python.terminal.activateEnvironment": true,
                "python.terminal.activateEnvInCurrentTerminal": true,
                "python.analysis.extraPaths": [
                    "/workspaces/llaminar/python"
                ],
                "python.autoComplete.extraPaths": [
                    "/workspaces/llaminar/python"
                ],
                "python.testing.pytestEnabled": true,
                "python.testing.pytestArgs": [
                    "python/reference/tests"
                ],
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.formatting.provider": "black",
                "gcovViewer.buildDirectories": [
                    "${workspaceFolder}/build"
                ]
            }
        }
    },
    "forwardPorts": [
        8080,
        3000,
        5000
    ],
    "postCreateCommand": "bash -c 'sudo chmod 666 /dev/dri/render* 2>/dev/null || true && sudo chown -R vscode:vscode /workspaces/llaminar || true && git config --global --add safe.directory /workspaces/llaminar && bash /workspaces/llaminar/.devcontainer/setup-ccache.sh && bash /workspaces/llaminar/.devcontainer/setup-python-env.sh && gh auth login && GH_USER=$(gh api user --jq .login) && GH_NAME=$(gh api user --jq .name) && GH_ID=$(gh api user --jq .id) && git config --global user.name \"${GH_NAME:-$GH_USER}\" && git config --global user.email \"${GH_ID}+${GH_USER}@users.noreply.github.com\" && cmake --version && gcc --version'",
    "postStartCommand": "bash /workspaces/llaminar/.devcontainer/onstart.sh",
    "postAttachCommand": "bash /workspaces/llaminar/.devcontainer/onstart.sh",
    "remoteUser": "vscode",
    "overrideCommand": false,
    "runArgs": [
        "--privileged",
        "--cap-add=SYS_ADMIN",
        "--security-opt",
        "apparmor=unconfined",
        "--device=/dev/kfd",
        "--device=/dev/dri",
        "--group-add=video",
        "--group-add=render",
        "--ipc=host",
        "--shm-size=32g",
        "--gpus=all"
    ],
    "containerEnv": {
        "VIRTUAL_ENV": "/workspaces/llaminar/.venv",
        "HSA_OVERRIDE_GFX_VERSION": "9.0.6"
    },
    "mounts": [
        "source=/opt/llaminar-models,target=/opt/llaminar-models,type=bind,consistency=cached"
    ]
}
