{
    "name": "Llaminar CMake Development",
    "dockerFile": "Dockerfile",
    "build": {
        "args": {
            "INSTALL_CUDA": "true",
            "INSTALL_ROCM": "true"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "20"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools-themes",
                "ms-python.python",
                "ms-python.pylint",
                "ms-python.debugpy",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "redhat.vscode-yaml",
                "ms-vscode.vscode-json",
                "bradlc.vscode-tailwindcss",
                "esbenp.prettier-vscode",
                "jacqueslucke.gcov-viewer"
            ],
            "settings": {
                "cmake.configureOnOpen": true,
                "cmake.buildBeforeRun": true,
                "cmake.clearOutputBeforeBuild": true,
                "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
                "C_Cpp.default.cStandard": "c17",
                "C_Cpp.default.cppStandard": "c++20",
                "C_Cpp.default.compilerPath": "/usr/bin/gcc",
                "files.associations": {
                    "*.h": "c",
                    "*.hpp": "cpp",
                    "*.cpp": "cpp",
                    "*.cc": "cpp",
                    "*.cxx": "cpp",
                    "CMakeLists.txt": "cmake",
                    "*.cmake": "cmake"
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/workspaces/llaminar/.venv/bin/python",
                "python.terminal.activateEnvironment": true,
                "python.terminal.activateEnvInCurrentTerminal": true,
                "python.analysis.extraPaths": [
                    "/workspaces/llaminar/python"
                ],
                "python.autoComplete.extraPaths": [
                    "/workspaces/llaminar/python"
                ],
                "python.testing.pytestEnabled": true,
                "python.testing.pytestArgs": [
                    "python/reference/tests"
                ],
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.formatting.provider": "black",
                "gcovViewer.buildDirectories": [
                    "${workspaceFolder}/build"
                ]
            }
        }
    },
    "forwardPorts": [
        8080,
        3000,
        5000
    ],
    "containerEnv": {
        "VIRTUAL_ENV": "/workspaces/llaminar/.venv"
    },
    "postCreateCommand": "bash -c 'sudo chown -R vscode:vscode /workspace || true && git config --global --add safe.directory /workspaces/llaminar && bash /workspaces/llaminar/.devcontainer/setup-ccache.sh && bash /workspaces/llaminar/.devcontainer/setup-python-env.sh && cmake --version && gcc --version'",
    "remoteUser": "vscode",
    "overrideCommand": false,
    "runArgs": [
        "--privileged",
        "--cap-add=SYS_ADMIN",
        "--security-opt",
        "apparmor=unconfined"
    ],
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
    ]
}