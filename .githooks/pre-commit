#!/bin/bash
# Pre-commit hook template for Llaminar project
# 
# Installation:
#   cp .githooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Branch-aware pre-commit checks:
#   master:  Full suite — build, unit tests, parity (Qwen2+Qwen35),
#            NodeLocalTP parity, E2E server tests, and performance benchmarks.
#   other:   Light suite — build, unit tests, and E2E server tests only.
#
# Override with: git commit --no-verify

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Determine target branch.  During a merge into master the env var
# GIT_REFLOG_ACTION contains "merge" and MERGE_HEAD is set, but the
# most reliable way is to check the branch name directly.
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
FULL_SUITE=false
if [ "$BRANCH" = "master" ]; then
    FULL_SUITE=true
fi

if [ "$FULL_SUITE" = true ]; then
    SUITE_LABEL="FULL (master)"
    TOTAL_STEPS=8
else
    SUITE_LABEL="LIGHT (branch: $BRANCH)"
    TOTAL_STEPS=3
fi

echo -e "${BLUE}==============================================================${NC}"
echo -e "${BLUE}Pre-commit Hook: ${SUITE_LABEL}${NC}"
echo -e "${BLUE}==============================================================${NC}"
echo ""

# Build directory
BUILD_V2_INTEGRATION="build_v2_integration"

# Step 1: Build Integration (Release optimizations + debug symbols + assertions)
echo -e "${YELLOW}[1/${TOTAL_STEPS}] Building V2 Integration...${NC}"
if ! cmake -B "$BUILD_V2_INTEGRATION" -S src/v2 -G Ninja -DCMAKE_BUILD_TYPE=Integration > /dev/null 2>&1; then
    echo -e "${RED}❌ CMake configuration failed (Integration)${NC}"
    exit 1
fi

if ! cmake --build "$BUILD_V2_INTEGRATION" --parallel > /dev/null 2>&1; then
    echo -e "${RED}❌ Build failed (Integration)${NC}"
    echo -e "${YELLOW}Run manually to see errors: cmake --build $BUILD_V2_INTEGRATION --parallel${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Integration build successful${NC}"
echo ""

# Step 2: Run Unit Tests (Integration build — fast, isolated component tests only)
echo -e "${YELLOW}[2/${TOTAL_STEPS}] Running V2 unit tests (Integration build)...${NC}"
echo ""

# Filter: ^V2_Unit_ matches all unit tests (excludes Integration, E2E, Performance)
# --parallel: Run unit tests in parallel for faster execution
set +e
ctest --test-dir "$BUILD_V2_INTEGRATION" -R "^V2_Unit_" --output-on-failure --parallel
UNIT_EXIT_CODE=$?
set -e

if [ $UNIT_EXIT_CODE -ne 0 ]; then
    echo ""
    echo -e "${RED}❌ Unit tests failed.${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Unit tests passed${NC}"
echo ""

# Steps 3-6: Parity and NodeLocalTP tests (master only)
if [ "$FULL_SUITE" = true ]; then

# Step 3: Run Qwen2 SingleDevice Parity Tests (prefill + decode, ~2 min)
# Validates inference accuracy across CPU/CUDA/ROCm with multiple KV cache configs.
# Catches accuracy regressions in attention, GEMM, and graph wiring.
echo -e "${YELLOW}[3/${TOTAL_STEPS}] Running Qwen2 SingleDevice parity tests (prefill + decode)...${NC}"
echo ""

set +e
ctest --test-dir "$BUILD_V2_INTEGRATION" -R "^V2_Integration_Parity_Qwen2_SingleDevice$" --output-on-failure --timeout 600
PARITY_EXIT_CODE=$?
set -e

echo ""
if [ $PARITY_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Qwen2 parity tests failed — possible accuracy regression.${NC}"
    echo ""
    echo -e "${YELLOW}Run manually for details:${NC}"
    echo -e "${YELLOW}  ctest --test-dir $BUILD_V2_INTEGRATION -R V2_Integration_Parity_Qwen2_SingleDevice -V${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Qwen2 parity tests passed${NC}"
echo ""

# Step 4: Run Qwen35 SingleDevice Parity Tests (prefill + decode)
# Validates Qwen3.5 hybrid GDN/FA architecture: GatedDeltaNet recurrence,
# short convolution, Q-gate split, partial RoPE, and sigmoid output gate.
# GPU configs are automatically skipped (CPU-only kernels).
# NOTE: 4B model decode parity is excluded (known pre-existing failure due to
# different GGUF weight naming conventions in the 4B checkpoint).
echo -e "${YELLOW}[4/${TOTAL_STEPS}] Running Qwen35 SingleDevice parity tests (prefill + decode)...${NC}"
echo ""

set +e
GTEST_FILTER="*08B*" ctest --test-dir "$BUILD_V2_INTEGRATION" -R "^V2_Integration_Parity_Qwen35_SingleDevice$" --output-on-failure --timeout 600
QWEN35_PARITY_EXIT_CODE=$?
set -e

echo ""
if [ $QWEN35_PARITY_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Qwen35 parity tests failed — possible accuracy regression in GDN/FA layers.${NC}"
    echo ""
    echo -e "${YELLOW}Run manually for details:${NC}"
    echo -e "${YELLOW}  ctest --test-dir $BUILD_V2_INTEGRATION -R V2_Integration_Parity_Qwen35_SingleDevice -V${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Qwen35 parity tests passed${NC}"
echo ""

# Step 5: Run Qwen2 NodeLocalTP Parity Tests (multi-device TP)
# Validates node-local tensor parallel correctness: weight sharding,
# AllReduce/AllGather collectives, and multi-device inference parity.
echo -e "${YELLOW}[5/${TOTAL_STEPS}] Running Qwen2 NodeLocalTP parity tests...${NC}"
echo ""

set +e
ctest --test-dir "$BUILD_V2_INTEGRATION" -R "^V2_Integration_Parity_NodeLocalTP$" --output-on-failure --timeout 600
QWEN2_NLTP_EXIT_CODE=$?
set -e

echo ""
if [ $QWEN2_NLTP_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Qwen2 NodeLocalTP parity tests failed — possible TP regression.${NC}"
    echo ""
    echo -e "${YELLOW}Run manually for details:${NC}"
    echo -e "${YELLOW}  ctest --test-dir $BUILD_V2_INTEGRATION -R V2_Integration_Parity_NodeLocalTP -V${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Qwen2 NodeLocalTP parity tests passed${NC}"
echo ""

# Step 6: Run Qwen35 NodeLocalTP Parity Tests (multi-device TP)
# Validates Qwen3.5 GDN/FA hybrid architecture under tensor parallelism:
# FusedQKV 3-sub-block sharding, tied embedding LM head, GDN weight distribution.
echo -e "${YELLOW}[6/${TOTAL_STEPS}] Running Qwen35 NodeLocalTP parity tests...${NC}"
echo ""

set +e
GTEST_FILTER="*08B*" ctest --test-dir "$BUILD_V2_INTEGRATION" -R "^V2_Integration_Parity_Qwen35_NodeLocalTP$" --output-on-failure --timeout 600
QWEN35_NLTP_EXIT_CODE=$?
set -e

echo ""
if [ $QWEN35_NLTP_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Qwen35 NodeLocalTP parity tests failed — possible TP regression in GDN/FA layers.${NC}"
    echo ""
    echo -e "${YELLOW}Run manually for details:${NC}"
    echo -e "${YELLOW}  ctest --test-dir $BUILD_V2_INTEGRATION -R V2_Integration_Parity_Qwen35_NodeLocalTP -V${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Qwen35 NodeLocalTP parity tests passed${NC}"
echo ""

fi # end FULL_SUITE (parity + NodeLocalTP tests)

# Compute E2E step number: 3 on light, 7 on full
if [ "$FULL_SUITE" = true ]; then
    E2E_STEP=7
else
    E2E_STEP=3
fi

# E2E Server Integration Tests (~2 min)
# Spins up llaminar2 --serve on CPU, CUDA, and ROCm, validates multi-turn
# inference via the REST API with curl.
echo -e "${YELLOW}[${E2E_STEP}/${TOTAL_STEPS}] Running E2E Server integration tests (cpu, cuda:0, rocm:0)...${NC}"
echo ""

set +e
tests/v2/e2e/server/test_server_e2e.sh \
    --binary "$BUILD_V2_INTEGRATION/llaminar2" \
    --backends "cpu,cuda:0,rocm:0"
SERVER_EXIT_CODE=$?
set -e

echo ""
if [ $SERVER_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ E2E Server tests failed.${NC}"
    echo ""
    echo -e "${YELLOW}Run manually for details:${NC}"
    echo -e "${YELLOW}  tests/v2/e2e/server/test_server_e2e.sh${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ E2E server tests passed${NC}"
echo ""

# Performance Regression Benchmarks (master only)
if [ "$FULL_SUITE" = true ]; then

# Runs --benchmark for each model × device combination defined in
# benchmark_baseline.json and compares prefill/decode throughput against
# canonical baselines. Devices that are unavailable are skipped gracefully.
echo -e "${YELLOW}[8/${TOTAL_STEPS}] Running performance regression benchmarks...${NC}"
echo ""

REPO_ROOT="$(git rev-parse --show-toplevel)"
set +e
"$REPO_ROOT/.githooks/run_benchmark_check.sh"
BENCH_EXIT_CODE=$?
set -e

echo ""
if [ $BENCH_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Performance regression detected.${NC}"
    echo ""
    echo -e "${YELLOW}If the regression is expected, update the baseline:${NC}"
    echo -e "${YELLOW}  .githooks/run_benchmark_check.sh --update-baseline${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix performance or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Performance benchmarks passed${NC}"
echo ""

fi # end FULL_SUITE (performance benchmarks)

echo "================================================"
echo -e "${GREEN}✅ SUCCESS: All checks passed! (${SUITE_LABEL})${NC}"
echo -e "${GREEN}  • Integration build: OK${NC}"
echo -e "${GREEN}  • Unit tests: OK${NC}"
if [ "$FULL_SUITE" = true ]; then
echo -e "${GREEN}  • Qwen2 parity: OK${NC}"
echo -e "${GREEN}  • Qwen35 parity: OK${NC}"
echo -e "${GREEN}  • Qwen2 NodeLocalTP parity: OK${NC}"
echo -e "${GREEN}  • Qwen35 NodeLocalTP parity: OK${NC}"
fi
echo -e "${GREEN}  • E2E server tests: OK${NC}"
if [ "$FULL_SUITE" = true ]; then
echo -e "${GREEN}  • Performance benchmarks: OK${NC}"
fi
echo ""
echo -e "${GREEN}Proceeding with commit...${NC}"
exit 0
