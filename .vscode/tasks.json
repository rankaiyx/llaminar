{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-S",
                "${workspaceFolder}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCMAKE_CXX_FLAGS_DEBUG=-g -O0 --coverage -fprofile-abs-path",
                "-DCMAKE_C_FLAGS_DEBUG=-g -O0 --coverage -fprofile-abs-path",
                "-DCMAKE_EXE_LINKER_FLAGS_DEBUG=--coverage"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure CMake project with Debug settings (includes coverage)"
        },
        {
            "label": "cmake: configure (release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_release",
                "-S",
                "${workspaceFolder}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCOSMA_WITH_PROFILING=OFF",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DCOSMA_SCALAPACK=CUSTOM",
                "-DCOSMA_SCALAPACK_LINK_LIBRARIES=/usr/lib/x86_64-linux-gnu/libscalapack-openmpi.so"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure CMake project with optimized Release settings"
        },
        {
            "label": "cmake: build (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "cmake: configure (debug)",
            "detail": "Build CMake project in Debug mode"
        },
        {
            "label": "cmake: build (release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_release",
                "--config",
                "Release",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "cmake: configure (release)",
            "detail": "Build CMake project in Release mode"
        },
        {
            "label": "cmake: clean (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean Debug build artifacts"
        },
        {
            "label": "cmake: clean (release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_release",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean Release build artifacts"
        },
        {
            "label": "test: smoke tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel",
                "-R",
                "^(BasicTest|NumaTest|PipelineFactoryTest|DequantTest|TPPartitionSpecTest|LargeMatmulPlanTest|WeightRoleClassification|MPILinearKernelTest|MPIRMSNormKernelTest|MPIAttentionKernelTest|MPISoftmaxCorrectnessTest|RMSNormCoreCorrectness|SoftmaxCoreCorrectness|LinearOrientationCorrectnessTest)$"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build (debug)",
            "detail": "Run quick smoke tests (~5s, 14 tests) - core functionality validation"
        },
        {
            "label": "test: parity tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--verbose",
                "-R",
                "(ParityFrameworkTest|AbstractPipelineParity)"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build (debug)",
            "detail": "Run parity tests - PyTorch and llama.cpp comparisons (~4min)"
        },
        {
            "label": "test: unit tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel",
                "-E",
                "(Integration|ParityFrameworkTest|Incremental|Qwen|Prefill|.*Stress.*)"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build (debug)",
            "detail": "Run all unit tests - no heavy integration (~2m30s)"
        },
        {
            "label": "bench: run performance benchmarks",
            "type": "shell",
            "command": "${workspaceFolder}/run_performance_bench.sh",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build (release)",
            "detail": "Run performance benchmarks (requires Release build)"
        },
        {
            "label": "gcov: show coverage metrics",
            "type": "shell",
            "command": "${workspaceFolder}/.vscode/show-coverage.sh",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Display coverage metrics summary from gcov"
        },
        {
            "label": "gcov: reset coverage data",
            "type": "shell",
            "command": "find",
            "args": [
                "${workspaceFolder}/build",
                "-name",
                "*.gcda",
                "-delete"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Delete all .gcda coverage data files to start fresh"
        }
    ]
}
