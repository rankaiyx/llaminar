{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-S",
                "${workspaceFolder}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure CMake project with debug settings"
        },
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Build the CMake project",
            "dependsOn": "cmake: configure"
        },
        {
            "label": "cmake: clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean the CMake build"
        },
        {
            "label": "cmake: rebuild",
            "type": "shell",
            "command": "echo",
            "args": [
                "Running clean and build..."
            ],
            "group": "build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "cmake: clean",
                "cmake: build"
            ],
            "detail": "Clean and rebuild the CMake project"
        },
        {
            "label": "cmake: build core",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "llaminar_core",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "cmake: configure",
            "detail": "Build only the llaminar core library"
        },
        {
            "label": "cmake: build COSMA",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "cosma",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "cmake: configure",
            "detail": "Build only the COSMA library"
        },
        {
            "label": "cmake: build main",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "llaminar",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "cmake: configure",
            "detail": "Build only the llaminar executable"
        },
        {
            "label": "cmake: configure Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-S",
                "${workspaceFolder}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCOSMA_WITH_PROFILING=OFF",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DCOSMA_SCALAPACK=CUSTOM",
                "-DCOSMA_SCALAPACK_LINK_LIBRARIES=/usr/lib/x86_64-linux-gnu/libscalapack-openmpi.so"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure CMake project with optimized Release settings"
        },
        {
            "label": "cmake: build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Release",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Build the CMake project in Release mode",
            "dependsOn": "cmake: configure Release"
        },
        {
            "label": "test: run ctest",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run all CTest tests with parallel execution (Note: Some tests currently fail due to numerical precision and validation issues)"
        },
        {
            "label": "test: run ctest verbose",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--verbose",
                "--parallel"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run all CTest tests with verbose output"
        },
        {
            "label": "test: show test status",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "echo '=== TEST STATUS SUMMARY ===' && cd ${workspaceFolder} && ctest --test-dir build --output-on-failure --parallel | tail -20"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Show summary of test pass/fail status"
        },
        {
            "label": "test: fast core",
            "type": "process",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--stop-on-failure",
                "-R",
                "^(BasicTest|NumaTest|GraphTest|MPILinearKernelTest)$"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run a fast core subset of stable tests"
        },
        {
            "label": "mpi: run (2 processes)",
            "type": "shell",
            "command": "mpirun",
            "args": [
                "-np",
                "2",
                "${workspaceFolder}/build/${input:targetName}"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run MPI application for Llaminar with 2 processes (2 NUMA nodes)"
        },
        {
            "label": "test: run MPI tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--verbose",
                "--test-dir",
                "${workspaceFolder}/build"
            ],
            "group": "test",
            "dependsOn": "cmake: build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Run the MPI functionality tests via CTest"
        },
        {
            "label": "mpi: run (4 processes)",
            "type": "shell",
            "command": "mpirun",
            "args": [
                "-np",
                "4",
                "${workspaceFolder}/build/${input:targetName}"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run MPI application with 4 processes"
        },
        {
            "label": "mpi: run llaminar (2 processes)",
            "type": "shell",
            "command": "mpirun",
            "args": [
                "-np",
                "2",
                "${workspaceFolder}/build/llaminar"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build main",
            "detail": "Run llaminar with 2 MPI processes"
        },
        {
            "label": "test: smoke (fast core tests)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel",
                "-R",
                "^(BasicTest|NumaTest|PipelineFactoryTest|DequantTest|TPPartitionSpecTest|LargeMatmulPlanTest|WeightRoleClassification|MPILinearKernelTest|MPIRMSNormKernelTest|MPIAttentionKernelTest|MPISoftmaxCorrectnessTest|RMSNormCoreCorrectness|SoftmaxCoreCorrectness|LinearOrientationCorrectnessTest)$"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run quick smoke tests (~5s total, 14 tests) - core functionality validation"
        },
        {
            "label": "test: unit (all unit tests)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel",
                "-E",
                "(Integration|ParityFramework|Incremental|Qwen|Prefill|.*Stress.*)"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run all unit tests, no heavy integration (<5min)"
        },
        {
            "label": "test: parity integration",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--verbose",
                "-R",
                "(ParityFramework|AbstractPipelineParity)"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run only ParityFramework tests - llama.cpp and PyTorch comparisons (~2min)"
        },
        {
            "label": "test: integration (heavy tests)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--verbose",
                "-R",
                "(Integration|Incremental|Qwen|Prefill|End2End|KVCache)"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run integration tests with model loading (<10min)"
        },
        {
            "label": "test: full suite",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build",
                "--output-on-failure",
                "--parallel"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "cmake: build",
            "detail": "Run complete test suite - all ~120 tests (<15min)"
        }
    ],
    "inputs": [
        {
            "id": "targetName",
            "description": "Target executable name",
            "default": "llaminar",
            "type": "promptString"
        }
    ]
}