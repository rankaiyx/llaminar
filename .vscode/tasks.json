{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "V2: configure (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON",
                "-DCMAKE_CXX_FLAGS_DEBUG=-g -O0 --coverage -fprofile-abs-path",
                "-DCMAKE_C_FLAGS_DEBUG=-g -O0 --coverage -fprofile-abs-path",
                "-DCMAKE_EXE_LINKER_FLAGS_DEBUG=--coverage"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure V2 project with Debug settings (CUDA + ROCm enabled)"
        },
        {
            "label": "V2: configure (release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2_release",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure V2 project with optimized Release settings (CUDA + ROCm enabled)"
        },
        {
            "label": "V2: configure (e2e release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2_e2e_release",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=E2ERelease",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Configure V2 project with E2ERelease (Release optimizations + snapshots + CUDA + ROCm)"
        },
        {
            "label": "Debug Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2",
                "--config",
                "Debug",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "V2: configure (debug)",
            "detail": "Build V2 project in Debug mode"
        },
        {
            "label": "Release Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_release",
                "--config",
                "Release",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "V2: configure (release)",
            "detail": "Build V2 project in Release mode"
        },
        {
            "label": "E2E Release Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_e2e_release",
                "--config",
                "E2ERelease",
                "--parallel"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": "V2: configure (e2e release)",
            "detail": "Build V2 project in E2ERelease mode (Release optimizations + snapshots)"
        },
        {
            "label": "V2: clean (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean V2 Debug build artifacts"
        },
        {
            "label": "V2: clean (release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_release",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean V2 Release build artifacts"
        },
        {
            "label": "V2: clean (e2e release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_e2e_release",
                "--target",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Clean V2 E2ERelease build artifacts"
        },
        {
            "label": "V2: test all",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "ctest --test-dir ${workspaceFolder}/build_v2 --output-on-failure --parallel && ${workspaceFolder}/.vscode/show-coverage-v2.sh"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "Debug Build",
            "detail": "Run all V2 tests + show coverage report"
        },
        {
            "label": "Run Unit Tests",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "ctest --test-dir ${workspaceFolder}/build_v2 --output-on-failure --parallel -R '^V2_Unit_' && ${workspaceFolder}/.vscode/show-coverage-v2.sh"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "Debug Build",
            "detail": "Run V2 unit tests (Debug build) + show coverage report"
        },
        {
            "label": "Run Integration Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_release",
                "--output-on-failure",
                "--parallel",
                "-R",
                "^V2_Integration_"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "Release Build",
            "detail": "Run V2 integration tests (Release build)"
        },
        {
            "label": "Run E2E Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_e2e_release",
                "--output-on-failure",
                "-R",
                "^V2_E2E_"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "E2E Release Build",
            "detail": "Run V2 end-to-end parity tests (E2ERelease build with snapshots)"
        },
        {
            "label": "V2: test performance",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_release",
                "--output-on-failure",
                "--verbose",
                "-R",
                "^V2_Perf_"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "Release Build",
            "detail": "Run V2 performance benchmarks (tests/v2/performance/) - requires Release build"
        },
        {
            "label": "V2: test parity",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2",
                "--output-on-failure",
                "--verbose",
                "-R",
                "^V2_Parity_"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "Debug Build",
            "detail": "Run V2 parity tests (future: tests/v2/parity/)"
        }
    ]
}
