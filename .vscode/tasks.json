{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "V2: configure debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCMAKE_CUDA_ARCHITECTURES=86",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure the V2 Debug build. Use for debugging only."
        },
        {
            "label": "V2: configure integration",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2_integration",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=Integration",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCMAKE_CUDA_ARCHITECTURES=86",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure the V2 Integration build used by unit, integration, and parity tests."
        },
        {
            "label": "V2: configure release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build_v2_release",
                "-S",
                "${workspaceFolder}/src/v2",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DCMAKE_CUDA_ARCHITECTURES=86",
                "-DHAVE_CUDA=ON",
                "-DHAVE_ROCM=ON"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure the V2 Release build used by performance tests and local E2E server runs."
        },
        {
            "label": "V2: build debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2",
                "--parallel"
            ],
            "group": "build",
            "dependsOn": "V2: configure debug",
            "problemMatcher": [],
            "detail": "Build the V2 Debug tree with full parallelism."
        },
        {
            "label": "V2: build integration",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_integration",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "V2: configure integration",
            "problemMatcher": [],
            "detail": "Build the V2 Integration tree with full parallelism."
        },
        {
            "label": "V2: build release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_release",
                "--parallel"
            ],
            "group": "build",
            "dependsOn": "V2: configure release",
            "problemMatcher": [],
            "detail": "Build the V2 Release tree with full parallelism."
        },
        {
            "label": "V2: build llaminar2 release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_release",
                "--parallel",
                "--target",
                "llaminar2"
            ],
            "group": "build",
            "dependsOn": "V2: configure release",
            "problemMatcher": [],
            "detail": "Build only the release llaminar2 executable and dependencies."
        },
        {
            "label": "V2: docker build runtime cpu",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/docker/build-runtime-image.sh",
            "args": [
                "--variant",
                "cpu",
                "--tag",
                "llaminar:local-cpu",
                "--load",
                "--verify"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build and load the local CPU-only Llaminar runtime image."
        },
        {
            "label": "V2: docker build runtime cuda",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/docker/build-runtime-image.sh",
            "args": [
                "--variant",
                "cuda",
                "--tag",
                "llaminar:local-cuda",
                "--load",
                "--verify"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build and load the local CPU+CUDA Llaminar runtime image."
        },
        {
            "label": "V2: docker build runtime rocm",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/docker/build-runtime-image.sh",
            "args": [
                "--variant",
                "rocm",
                "--tag",
                "llaminar:local-rocm",
                "--load",
                "--verify"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build and load the local CPU+ROCm Llaminar runtime image."
        },
        {
            "label": "V2: docker build runtime full",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/docker/build-runtime-image.sh",
            "args": [
                "--variant",
                "full",
                "--tag",
                "llaminar:local",
                "--tag",
                "llaminar:local-full",
                "--load",
                "--verify"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build and load the local CPU+CUDA+ROCm Llaminar runtime image."
        },
        {
            "label": "V2: docker build runtime matrix",
            "type": "shell",
            "command": "true",
            "dependsOrder": "sequence",
            "dependsOn": [
                "V2: docker build runtime cpu",
                "V2: docker build runtime cuda",
                "V2: docker build runtime rocm",
                "V2: docker build runtime full"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build every local Llaminar runtime image variant sequentially."
        },
        {
            "label": "V2: build all canonical",
            "type": "shell",
            "command": "true",
            "dependsOrder": "sequence",
            "dependsOn": [
                "V2: build debug",
                "V2: build integration",
                "V2: build release"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Build Debug, Integration, and Release trees using the canonical directories."
        },
        {
            "label": "V2: clean debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2",
                "--target",
                "clean"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean the V2 Debug build tree."
        },
        {
            "label": "V2: clean integration",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_integration",
                "--target",
                "clean"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean the V2 Integration build tree."
        },
        {
            "label": "V2: clean release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_v2_release",
                "--target",
                "clean"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean the V2 Release build tree."
        },
        {
            "label": "V2: test unit",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_integration",
                "-R",
                "^V2_Unit_",
                "--output-on-failure",
                "--parallel"
            ],
            "group": "test",
            "dependsOn": "V2: build integration",
            "problemMatcher": [],
            "detail": "Run V2 unit tests from the Integration build."
        },
        {
            "label": "V2: test integration",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_integration",
                "-R",
                "^V2_Integration_",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": "V2: build integration",
            "problemMatcher": [],
            "detail": "Run V2 integration tests from the Integration build."
        },
        {
            "label": "V2: test parity",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_integration",
                "-R",
                "^V2_Integration_Parity_",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": "V2: build integration",
            "problemMatcher": [],
            "detail": "Run V2 parity tests from the Integration build."
        },
        {
            "label": "V2: test performance",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_release",
                "-R",
                "^V2_Perf_",
                "--verbose"
            ],
            "group": "test",
            "dependsOn": "V2: build release",
            "problemMatcher": [],
            "detail": "Run V2 performance tests from the Release build."
        },
        {
            "label": "V2: test integration tree",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build_v2_integration",
                "--output-on-failure",
                "--parallel"
            ],
            "group": "test",
            "dependsOn": "V2: build integration",
            "problemMatcher": [],
            "detail": "Run every registered test in the Integration build tree."
        },
        {
            "label": "V2: parity baseline",
            "type": "shell",
            "command": "${workspaceFolder}/.githooks/run_parity_baseline.sh",
            "args": [
                "${workspaceFolder}/build_v2_integration"
            ],
            "group": "test",
            "dependsOn": "V2: build integration",
            "problemMatcher": [],
            "detail": "Run the focused pre-commit parity baseline against build_v2_integration."
        },
        {
            "label": "V2: e2e server local",
            "type": "shell",
            "command": "${workspaceFolder}/tests/v2/e2e/server/test_server_e2e.sh",
            "args": [
                "--binary",
                "${workspaceFolder}/build_v2_release/llaminar2",
                "--backends",
                "cpu,cuda:0,rocm:0"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_LONG_CONTEXT": "0"
                }
            },
            "group": "test",
            "dependsOn": "V2: build llaminar2 release",
            "problemMatcher": [],
            "detail": "Run the serialized local server E2E harness with the Release binary."
        },
        {
            "label": "V2: e2e server local pre-commit",
            "type": "shell",
            "command": "${workspaceFolder}/tests/v2/e2e/server/test_server_e2e.sh",
            "args": [
                "--binary",
                "${workspaceFolder}/build_v2_release/llaminar2",
                "--backends",
                "cpu,cuda:0,rocm:0"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_LONG_CONTEXT": "1",
                    "LLAMINAR_E2E_LONG_CONTEXT_TIER": "full",
                    "LLAMINAR_E2E_CONTEXT_LENGTH": "4096",
                    "LLAMINAR_E2E_LONG_MAX_TOKENS": "1024",
                    "LLAMINAR_E2E_LONG_MIN_PROMPT_TOKENS": "900",
                    "LLAMINAR_E2E_LONG_REQUEST_TIMEOUT": "1800",
                    "LLAMINAR_E2E_LONG_MIN_MODEL_SIZE_B": "4"
                }
            },
            "group": "test",
            "dependsOn": "V2: build llaminar2 release",
            "problemMatcher": [],
            "detail": "Run the serialized local server E2E harness with pre-commit long-context settings."
        },
        {
            "label": "V2: e2e release container cpu",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ci/run_release_container_e2e.sh",
            "args": [
                "--variant",
                "cpu",
                "--image",
                "ghcr.io/llaminar/llaminar:develop-cpu-latest"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_DOCKER_NETWORK": "bridge"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the serialized CPU release-container E2E subset against the public develop image."
        },
        {
            "label": "V2: e2e release container cuda",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ci/run_release_container_e2e.sh",
            "args": [
                "--variant",
                "cuda",
                "--image",
                "ghcr.io/llaminar/llaminar:develop-cuda13.0-latest"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_DOCKER_NETWORK": "bridge"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the serialized CUDA release-container E2E subset against the public develop image."
        },
        {
            "label": "V2: e2e release container rocm",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ci/run_release_container_e2e.sh",
            "args": [
                "--variant",
                "rocm",
                "--image",
                "ghcr.io/llaminar/llaminar:develop-rocm7.1.1-latest"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_DOCKER_NETWORK": "bridge"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the serialized ROCm release-container E2E subset against the public develop image."
        },
        {
            "label": "V2: e2e release container hybrid",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ci/run_release_container_e2e.sh",
            "args": [
                "--variant",
                "hybrid",
                "--image",
                "ghcr.io/llaminar/llaminar:develop-latest"
            ],
            "options": {
                "env": {
                    "LLAMINAR_E2E_DOCKER_NETWORK": "bridge"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the serialized hybrid CUDA+ROCm release-container E2E subset against the public develop image."
        },
        {
            "label": "V2: e2e release container public matrix",
            "type": "shell",
            "command": "true",
            "dependsOrder": "sequence",
            "dependsOn": [
                "V2: e2e release container cpu",
                "V2: e2e release container cuda",
                "V2: e2e release container rocm",
                "V2: e2e release container hybrid"
            ],
            "group": "test",
            "problemMatcher": [],
            "detail": "Run all public release-container E2E subsets sequentially to avoid GPU oversubscription."
        },
        {
            "label": "V2: benchmark regression check",
            "type": "shell",
            "command": "${workspaceFolder}/.githooks/run_benchmark_check.sh",
            "group": "test",
            "dependsOn": "V2: build release",
            "problemMatcher": [],
            "detail": "Run the pre-commit performance regression benchmark check."
        },
        {
            "label": "Git: pre-commit suite",
            "type": "shell",
            "command": "${workspaceFolder}/.githooks/pre-commit",
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the repository pre-commit suite exactly as installed."
        }
    ]
}
