{
    "cmake.configureOnOpen": false,
    "cmake.buildBeforeRun": true,
    "cmake.clearOutputBeforeBuild": true,
    "cmake.sourceDirectory": "${workspaceFolder}/src/v2",
    "cmake.generator": "Ninja",
    "cmake.preferredGenerators": [
        "Ninja"
    ],
    "cmake.buildDirectory": "${workspaceFolder}/build_v2_integration",
    "cmake.configureSettings": {
        "CMAKE_BUILD_TYPE": "Integration",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "HAVE_CUDA": "ON",
        "HAVE_ROCM": "ON"
    },
    "cmake.installPrefix": "${workspaceFolder}/install",
    "cmake.debugConfig": {
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
    },
    "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.compilerPath": "/usr/bin/gcc",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/**",
        "/usr/include/**",
        "/usr/local/include/**",
        "/usr/lib/x86_64-linux-gnu/openmpi/include/**"
    ],
    "C_Cpp.default.defines": [
        "_GNU_SOURCE",
        "OMPI_SKIP_MPICXX=1"
    ],
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "files.associations": {
        "*.h": "c",
        "*.hpp": "cpp",
        "*.cpp": "cpp",
        "*.cc": "cpp",
        "*.cxx": "cpp",
        "CMakeLists.txt": "cmake",
        "*.cmake": "cmake",
        "*.md": "markdown",
        "any": "cpp",
        "array": "cpp",
        "charconv": "cpp",
        "chrono": "cpp",
        "compare": "cpp",
        "functional": "cpp",
        "ratio": "cpp",
        "tuple": "cpp",
        "type_traits": "cpp",
        "utility": "cpp",
        "variant": "cpp",
        "bitset": "cpp",
        "string_view": "cpp",
        "initializer_list": "cpp",
        "ranges": "cpp",
        "regex": "cpp",
        "valarray": "cpp",
        "string": "cpp",
        "optional": "cpp",
        "system_error": "cpp",
        "sstream": "cpp",
        "atomic": "cpp",
        "complex": "cpp",
        "deque": "cpp",
        "forward_list": "cpp",
        "list": "cpp",
        "unordered_map": "cpp",
        "unordered_set": "cpp",
        "vector": "cpp",
        "iterator": "cpp",
        "memory_resource": "cpp",
        "stop_token": "cpp",
        "cmath": "cpp",
        "iosfwd": "cpp",
        "iostream": "cpp",
        "typeinfo": "c",
        "span": "cpp",
        "random": "cpp",
        "bit": "cpp",
        "cctype": "cpp",
        "cinttypes": "cpp",
        "clocale": "cpp",
        "codecvt": "cpp",
        "concepts": "cpp",
        "condition_variable": "cpp",
        "csignal": "cpp",
        "cstdarg": "cpp",
        "cstddef": "cpp",
        "cstdint": "cpp",
        "cstdio": "cpp",
        "cstdlib": "cpp",
        "cstring": "cpp",
        "ctime": "cpp",
        "cwchar": "cpp",
        "cwctype": "cpp",
        "map": "cpp",
        "set": "cpp",
        "exception": "cpp",
        "expected": "cpp",
        "algorithm": "cpp",
        "memory": "cpp",
        "numeric": "cpp",
        "source_location": "cpp",
        "format": "cpp",
        "fstream": "cpp",
        "future": "cpp",
        "iomanip": "cpp",
        "istream": "cpp",
        "limits": "cpp",
        "mutex": "cpp",
        "new": "cpp",
        "numbers": "cpp",
        "ostream": "cpp",
        "semaphore": "cpp",
        "shared_mutex": "cpp",
        "stdexcept": "cpp",
        "streambuf": "cpp",
        "thread": "cpp",
        "cfenv": "cpp",
        "typeindex": "cpp"
    },
    "files.exclude": {
        "**/build/**": true,
        "**/.git": false,
        "**/.DS_Store": true,
        "**/node_modules": true,
        "gpucore.*": true,
        "build_*/**": true,
        "external/**": true,
        "tmp/**": true,
        "pytorch_*/**": true,
        ".rocprofv3/**": true,
        ".venv/**": true,
        "**/__pycache__/**": true
    },
    "search.exclude": {
        "**/build/**": true,
        "**/node_modules": true,
        "gpucore.*": true,
        "build_*/**": true,
        "external/**": true,
        "tmp/**": true,
        "pytorch_*/**": true,
        ".rocprofv3/**": true,
        ".venv/**": true,
        "**/__pycache__/**": true
    },
    "files.watcherExclude": {
        "gpucore.*": true,
        "**/build/**": true,
        "build_*/**": true,
        "external/**": true,
        "tmp/**": true,
        "pytorch_*/**": true,
        ".git/**": true,
        ".rocprofv3/**": true,
        ".venv/**": true,
        "**/__pycache__/**": true,
        "**/node_modules/**": true
    },
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "[cpp]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[c]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[cmake]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.defaultFormatter": "vscode.markdown-language-features"
    },
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "/bin/bash",
            "args": []
        }
    },
    "git.autofetch": true,
    "git.confirmSync": false,
    "extensions.ignoreRecommendations": false,
    "chat.tools.global.autoApprove": true,
    "chat.tools.terminal.autoApprove": {
        "/.*/": true
    },
    "chat.todoListTool.enabled": true,
    "markdown.validate.enabled": true,
    "github.copilot.selectedCompletionModel": "claude-haiku-4.5",
    "github.copilot.chat.backgroundCompaction": true,
    "remote.autoForwardPorts": false,
    "github.copilot.chat.exploreAgent.model": "gpt-5.4-mini"
}
